      "parameters": {
        "jsCode": "const items = $input.all();\nconst first = items[0].json;\n\nconst {\n  category,\n  priority,\n  notification_required,\n  summary,\n  action,\n  event_time,\n  message_id,\n  thread_id\n} = first;\n\n// 🔒 SINGLE SOURCE OF TRUTH\nconst PRIORITY_LABEL_MAP = {\n  P1: \"🔥 P1\",\n  P2: \"⚠️ P2\",\n  P3: \"ℹ️ P3\"\n};\n\nconst labelNameToCheck = PRIORITY_LABEL_MAP[priority];\n\n// Find matching Gmail label by NAME\nconst matchedLabel = items.find(\n  item => item.json.name === labelNameToCheck\n);\n\nreturn [\n  {\n    json: {\n      category,\n      priority,\n      notification_required,\n      summary,\n      action,\n      event_time,\n      message_id,\n      thread_id,\n      label_apply: matchedLabel ? matchedLabel.json.id : null,\n      label_exists: !!matchedLabel\n    }\n  }\n];"
      },
