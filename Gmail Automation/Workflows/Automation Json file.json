    {
      "parameters": {
        "jsCode": "// === First Code node after Gmail Trigger ===\n\n// Get the email data from input\nconst email = $input.first().json;\n\n// Extract message ID (Gmail trigger usually puts it in \"id\")\nconst messageId = email.id;\n\n// threadId is usually already there\nconst threadId = email.threadId;\n\n// Assume 'text' is body or snippet — adjust if you have different field\nconst text = (email.snippet || email.body || \"\").toLowerCase();\n\n// Your category logic (keep or expand)\nlet category = \"Other\";  // default\n\nif (text.includes(\"job\") || text.includes(\"discussion\") || text.includes(\"production\") || \n    text.includes(\"standup\") || text.includes(\"meeting\") || text.includes(\"call\")) {\n  category = \"Work & Professional\";\n} else if (text.includes(\"bank\") || text.includes(\"account\") || text.includes(\"transaction\") || \n           text.includes(\"credit\") || text.includes(\"debit\") || text.includes(\"payment\")) {\n  category = \"Payments & Banking\";\n} else if (text.includes(\"bill\") || text.includes(\"invoice\") || text.includes(\"subscription\")) {\n  category = \"Bills & Subscriptions\";\n} else if (text.includes(\"shopping\") || text.includes(\"order\") || text.includes(\"delivery\")) {\n  category = \"Shopping & Orders\";\n}\n// ... add more conditions as needed\n\n// Always return structured output\nreturn [{\n  json: {\n    messageId: messageId,\n    threadId: threadId,\n    category: category,\n    // optional: keep other useful fields\n    snippet: email.snippet || \"\",\n    subject: email.headers?.subject || \"\",\n    from: email.headers?.from || \"\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
